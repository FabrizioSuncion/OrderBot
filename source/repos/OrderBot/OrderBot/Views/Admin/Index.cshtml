@{
    ViewData["Title"] = "Panel de Administración";
}

<div style="padding: 20px; font-family: Arial, sans-serif;">
    <h2 style="color: #1F4E79; margin-bottom: 20px;">Panel de Administración</h2>

    <!-- Tarjetas de resumen -->
    <div style="display: flex; gap: 20px; margin-bottom: 30px;">
        <div style="flex:1; background:#2E75B6; color:white; padding:20px; border-radius:12px; text-align:center;">
            <div style="font-size:36px; font-weight:bold;">@ViewBag.TotalPedidos</div>
            <div style="font-size:14px; margin-top:5px;">Total Pedidos</div>
        </div>
        <div style="flex:1; background:#1D9E75; color:white; padding:20px; border-radius:12px; text-align:center;">
            <div style="font-size:36px; font-weight:bold;">S/ @ViewBag.TotalVentas</div>
            <div style="font-size:14px; margin-top:5px;">Total Ventas</div>
        </div>
        <div style="flex:1; background:#E8593C; color:white; padding:20px; border-radius:12px; text-align:center;">
            <div style="font-size:36px; font-weight:bold;">@ViewBag.TotalProductos</div>
            <div style="font-size:14px; margin-top:5px;">Productos</div>
        </div>
    </div>

    <!-- Accesos rápidos -->
    <div style="display:flex; gap:12px; margin-bottom:30px;">
        <a href="/Admin/Productos" style="padding:10px 20px; background:#2E75B6; color:white; border-radius:8px; text-decoration:none;">Gestionar Productos</a>
        <a href="/Admin/Cocina" style="padding:10px 20px; background:#E8593C; color:white; border-radius:8px; text-decoration:none;">Tablero de Cocina</a>
        <a href="/Chat" style="padding:10px 20px; background:#1D9E75; color:white; border-radius:8px; text-decoration:none;">Ir al Chatbot</a>
    </div>

    <!-- Últimos pedidos -->
    <h3 style="color:#1F4E79; margin-bottom:15px;">Últimos Pedidos</h3>
    <table style="width:100%; border-collapse:collapse; background:white; border-radius:12px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.1);">
        <thead>
            <tr style="background:#2E75B6; color:white;">
                <th style="padding:12px; text-align:left;">#</th>
                <th style="padding:12px; text-align:left;">Cliente</th>
                <th style="padding:12px; text-align:left;">Fecha</th>
                <th style="padding:12px; text-align:left;">Total</th>
                <th style="padding:12px; text-align:left;">Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in ViewBag.Pedidos)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td style="padding:12px;">#@pedido.Id</td>
                    <td style="padding:12px;">@pedido.ClienteNombre</td>
                    <td style="padding:12px;">@pedido.FechaPedido.ToString("dd/MM/yyyy HH:mm")</td>
                    <td style="padding:12px;">S/ @pedido.Total</td>
                    <td style="padding:12px;">
                        <span style="padding:4px 10px; border-radius:20px; font-size:12px;
                            background:@(pedido.Estado == "Pendiente" ? "#FFF3CD" : pedido.Estado == "Entregado" ? "#D4EDDA" : "#CCE5FF");
                            color:@(pedido.Estado == "Pendiente" ? "#856404" : pedido.Estado == "Entregado" ? "#155724" : "#004085");">
                            @pedido.Estado
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>