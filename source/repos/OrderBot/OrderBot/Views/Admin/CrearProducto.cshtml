@{
    ViewData["Title"] = "Nuevo Producto";
}

<div style="padding:20px; font-family:Arial, sans-serif; max-width:500px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h2 style="color:#1F4E79;">Nuevo Producto</h2>
        <a href="/Admin/Productos" style="padding:10px 20px; background:#666; color:white; border-radius:8px; text-decoration:none;">← Volver</a>
    </div>

    <div style="background:white; padding:24px; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.1);">
        <form method="post" action="/Admin/CrearProducto">
            <div style="margin-bottom:16px;">
                <label style="display:block; font-size:14px; font-weight:bold; color:#333; margin-bottom:6px;">Nombre</label>
                <input name="Nombre" type="text" required style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px; font-size:14px; box-sizing:border-box;" placeholder="Ej: Hamburguesa Especial" />
            </div>

            <div style="margin-bottom:16px;">
                <label style="display:block; font-size:14px; font-weight:bold; color:#333; margin-bottom:6px;">Descripción</label>
                <textarea name="Descripcion" rows="3" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px; font-size:14px; box-sizing:border-box;" placeholder="Ingredientes o descripción del producto"></textarea>
            </div>

            <div style="margin-bottom:16px;">
                <label style="display:block; font-size:14px; font-weight:bold; color:#333; margin-bottom:6px;">Precio (S/)</label>
                <input name="Precio" type="number" step="0.50" required style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px; font-size:14px; box-sizing:border-box;" placeholder="0.00" />
            </div>

            <div style="margin-bottom:16px;">
                <label style="display:block; font-size:14px; font-weight:bold; color:#333; margin-bottom:6px;">Categoría</label>
                <select name="CategoriaId" required style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px; font-size:14px; box-sizing:border-box;">
                    <option value="">Selecciona una categoría</option>
                    @foreach (var categoria in ViewBag.Categorias)
                    {
                        <option value="@categoria.Id">@categoria.Nombre</option>
                    }
                </select>
            </div>

            <div style="margin-bottom:20px;">
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                    <input name="Disponible" type="checkbox" checked value="true" style="width:18px; height:18px;" />
                    <span style="font-size:14px; font-weight:bold; color:#333;">Disponible</span>
                </label>
            </div>

            <button type="submit" style="width:100%; padding:12px; background:#2E75B6; color:white; border:none; border-radius:8px; font-size:16px; cursor:pointer;">
                Guardar Producto
            </button>
        </form>
    </div>
</div>